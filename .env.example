# Encryption secret for storing user API keys (any random string, min 16 chars)
# In production, use a long random string and keep it secret
ENCRYPTION_SECRET="change-me-to-a-random-secret-string"

# App deployment URL
APP_URL="http://localhost:3000"

# Server port (default: 3000)
PORT=3000

# CORS allowed origins, comma-separated (default: http://localhost:3000)
ALLOWED_ORIGINS="http://localhost:3000"

# Rate limiting — window in milliseconds (default: 900000 = 15 min)
RATE_LIMIT_WINDOW_MS=900000

# Rate limiting — max requests per window per IP (default: 100)
RATE_LIMIT_MAX=100

# SQLite database file path (use :memory: for tests)
DB_FILE="cloud_storage.db"
